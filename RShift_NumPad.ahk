#Requires AutoHotkey v2

; RShift + 숫자 → Numpad
~RShift & 1::Send("{Numpad1}")
~RShift & 2::Send("{Numpad2}")
~RShift & 3::Send("{Numpad3}")
~RShift & 4::Send("{Numpad4}")
~RShift & 5::Send("{Numpad5}")
~RShift & 6::Send("{Numpad6}")
~RShift & 7::Send("{Numpad7}")
~RShift & 8::Send("{Numpad8}")
~RShift & 9::Send("{Numpad9}")
~RShift & 0::Send("{Numpad0}")